{
  "name": "rabbitmq-ci-build-events",
  "version": "1.0.0",
  "description": "RabbitMQ advanced messaging patterns demo — CI build events",
  "private": true,
  "scripts": {
    "start": "ts-node src/index.ts",
    "publish:1": "ts-node src/publish.ts --producerId publisher-1",
